AUTH_TRUST_HOST="true"
NEXTAUTH_URL="your-domain.com"
NEXTAUTH_SECRET="secret-key"
NEXT_PUBLIC_BASE_URL="your-domain.com"
PUBLIC_API_KEY="api key"
GROQ_API_KEY="groq api key"
GOOGLE_VISION_API_KEY="google vision api key"

MONGODB_URI="mongodb+srv://<user>:<password>@cluster.mongodb.net/<db>"

AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-south-1
AWS_BUCKET_NAME=your-bucket-name
AWS_BASE_URL=https://your-bucket.s3.your-region.amazonaws.com

# ─── Baileys WhatsApp Service ─────────────────────────────────────────────
# Port for the Baileys Socket.IO server (separate process)
BAILEYS_SOCKET_PORT=3001

# URL that the frontend connects to for real-time Socket.IO events
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# ─── Meta WhatsApp Cloud API ────────────────────────────────────────────
# Port for the Meta Socket.IO server (separate process)
META_SOCKET_PORT=3002

# URL the frontend connects to for Meta real-time events
NEXT_PUBLIC_META_SOCKET_URL=http://localhost:3002

# URL the Next.js app connects to for emitting events to the Meta socket server
META_SOCKET_URL=http://localhost:3002

# Meta WhatsApp Cloud API credentials (per-channel config stored in DB)
# These are defaults for the webhook endpoint
WHATSAPP_APP_SECRET="your-app-secret"
WEBHOOK_VERIFY_TOKEN="your-verify-token"
